FROM arm32v6/node:18.20-alpine3.21

# Set working directory
WORKDIR /app

# Install nodemon globally
RUN npm install -g nodemon

# Copy package files first for better caching
COPY app/package*.json ./

# Install dependencies
RUN npm install

# Expose port
EXPOSE 4000

# Set up entry command
CMD ["sh", "-c", "mkdir -p /app/data && chmod 777 /app/data && npm run dev"]